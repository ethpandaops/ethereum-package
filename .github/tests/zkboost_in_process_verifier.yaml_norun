# EIP-8025 testnet demonstrating zkboost's in-process verifier path:
# one prover instance (real ZisK ere-server, GPU) + one verifier-only instance
# (no ere-server, ere-verifier-zisk linked into zkboost).
#
# Run with:
#   kurtosis run --enclave eip8025-in-process-verifier \
#       . \
#       --args-file .github/tests/zkboost_in_process_verifier.yaml_norun
#
# Prerequisites:
#   - 1 NVIDIA GPU (Blackwell, sm_120 — ethpandaops/ere-server-zisk:master is
#     compiled for CUDA_ARCH=sm_120; use ghcr.io/eth-act/ere/ere-server-zisk
#     for broader GPU support).
#
# Both zkboost and ere-server-zisk are pulled from the ethpandaops mirror at
# the moving `:master` tag (auto-tracks eth-act upstream master). The mirror
# for zkboost lands with ethpandaops/eth-client-docker-image-builder#377.
#
# `_resolve_ere_versions` only auto-resolves for the official eth-act zkboost
# image, so we bypass it by setting `image`/`elf_url`/`program_vk_url`
# explicitly per zkvm. Bump the ere-guests version (v0.9.0 below) when the
# upstream `:master` zkboost binary bumps its Cargo-pinned ere-guests dep.

participants:
  # Prover-side: uses zkboost-prover (real ere-server + GPU).
  - cl_type: lighthouse
    cl_image: ethpandaops/lighthouse:eth-act-optional-proofs
    el_type: reth
    el_image: ghcr.io/paradigmxyz/reth
    supernode: true
    cl_extra_params:
      - --target-peers=3
      - --proof-engine-endpoint=http://zkboost-prover:3000
      - --proof-types=6
    vc_extra_params:
      - --proof-engine-endpoint=http://zkboost-prover:3000
      - --proof-types=6
    count: 1
  # Verifier-only side: uses zkboost-verifier (no ere-server, in-process
  # ere-verifier-zisk). Listens for gossipped proofs and verifies them.
  # Lighthouse's optional-proofs subscribe path needs `--proof-types` on both
  # cl_extra_params and vc_extra_params to enable the gossip subscription, even
  # though zkboost-verifier rejects prove requests with an error (verifier-only).
  - cl_type: lighthouse
    cl_image: ethpandaops/lighthouse:eth-act-optional-proofs
    el_type: reth
    el_image: ghcr.io/paradigmxyz/reth
    supernode: false
    cl_extra_params:
      - --target-peers=3
      - --proof-engine-endpoint=http://zkboost-verifier:3000
      - --proof-types=6
    vc_extra_params:
      - --proof-engine-endpoint=http://zkboost-verifier:3000
      - --proof-types=6
    count: 1

network_params:
  seconds_per_slot: 30

additional_services:
  - zkboost
  - dora
  - prometheus
  - grafana
  - tempo

zkboost_params:
  image: ethpandaops/zkboost:master
  env:
    RUST_LOG: info,zkboost=debug
  instances:
    - name: zkboost-prover
      el_participant_index: 0
      zkvms:
        - kind: ere
          proof_type: reth-zisk
          image: ethpandaops/ere-server-zisk:master
          elf_url: https://github.com/eth-act/ere-guests/releases/download/v0.9.0/stateless-validator-reth-zisk.elf
          gpu:
            device_ids: ["0"]
    - name: zkboost-verifier
      el_participant_index: 1
      zkvms:
        - kind: verifier
          proof_type: reth-zisk
          program_vk_url: https://github.com/eth-act/ere-guests/releases/download/v0.9.0/stateless-validator-reth-zisk.vk
